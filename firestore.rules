rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.uid == "NoGsCqiKc0VJwWb6rppk7QVLV1B2" ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validOptionalString(value, max) {
      return value == null || (value is string && value.size() <= max);
    }

    function validOptionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function validProfileAddress(endereco) {
      return endereco is map &&
        endereco.keys().hasOnly(['rua', 'numero', 'cep', 'cidade']) &&
        validOptionalString(endereco.rua, 140) &&
        validOptionalString(endereco.numero, 40) &&
        validOptionalString(endereco.cep, 12) &&
        validOptionalString(endereco.cidade, 120);
    }

    function validUsuarioData() {
      return request.resource.data.keys().hasOnly([
          'nome',
          'email',
          'telefone',
          'endereco',
          'fotoUrl',
          'createdAt',
          'favoritos'
        ]) &&
        validString(request.resource.data.nome, 1, 120) &&
        validOptionalString(request.resource.data.email, 120) &&
        validOptionalString(request.resource.data.telefone, 30) &&
        (request.resource.data.endereco == null || validProfileAddress(request.resource.data.endereco)) &&
        validOptionalString(request.resource.data.fotoUrl, 500) &&
        validOptionalTimestamp(request.resource.data.createdAt) &&
        (
          resource == null
            ? (request.resource.data.createdAt == null || request.resource.data.createdAt == request.time)
            : request.resource.data.createdAt == resource.data.createdAt
        ) &&
        (
          request.resource.data.favoritos == null ||
          (
            request.resource.data.favoritos is list &&
            request.resource.data.favoritos.size() <= 200
          )
        );
    }

    function validEndereco(endereco) {
      return endereco is map &&
        endereco.keys().hasAll(['rua', 'numero', 'cep', 'cidade']) &&
        endereco.keys().hasOnly(['rua', 'numero', 'cep', 'cidade']) &&
        validString(endereco.rua, 1, 140) &&
        validString(endereco.numero, 1, 40) &&
        validString(endereco.cep, 8, 12) &&
        validString(endereco.cidade, 1, 120);
    }

    function validCliente(cliente) {
      return cliente is map &&
        cliente.keys().hasAll(['nome', 'telefone', 'email', 'endereco']) &&
        cliente.keys().hasOnly(['nome', 'telefone', 'email', 'endereco']) &&
        validString(cliente.nome, 2, 120) &&
        validString(cliente.telefone, 8, 30) &&
        validString(cliente.email, 5, 120) &&
        validEndereco(cliente.endereco);
    }

    function validAjustes(ajustes) {
      return ajustes is map &&
        ajustes.keys().hasAll(['pixDiscount', 'cardFee', 'freeShipping']) &&
        ajustes.keys().hasOnly(['pixDiscount', 'cardFee', 'freeShipping']) &&
        ajustes.pixDiscount is number &&
        ajustes.pixDiscount >= 0 &&
        ajustes.cardFee is number &&
        ajustes.cardFee >= 0 &&
        ajustes.freeShipping is bool;
    }

    function validFrete(frete) {
      return frete is map &&
        frete.keys().hasAll([
          'serviceId',
          'serviceCode',
          'name',
          'company',
          'price',
          'originalPrice',
          'deliveryTime',
          'quotedAt',
          'fromPostalCode',
          'toPostalCode',
          'freeShippingApplied'
        ]) &&
        frete.keys().hasOnly([
          'serviceId',
          'serviceCode',
          'name',
          'company',
          'price',
          'originalPrice',
          'deliveryTime',
          'quotedAt',
          'fromPostalCode',
          'toPostalCode',
          'freeShippingApplied'
        ]) &&
        validString(frete.serviceId, 1, 120) &&
        validString(frete.serviceCode, 1, 120) &&
        validString(frete.name, 1, 120) &&
        validString(frete.company, 1, 80) &&
        frete.price is number &&
        frete.price >= 0 &&
        frete.price <= 100000 &&
        frete.originalPrice is number &&
        frete.originalPrice >= frete.price &&
        frete.originalPrice <= 100000 &&
        frete.deliveryTime is int &&
        frete.deliveryTime >= 1 &&
        frete.deliveryTime <= 90 &&
        validString(frete.quotedAt, 10, 40) &&
        validString(frete.fromPostalCode, 8, 12) &&
        validString(frete.toPostalCode, 8, 12) &&
        frete.freeShippingApplied is bool;
    }

    function validPagamento(pagamento, parcelas) {
      return (
        pagamento == 'PIX' &&
        parcelas == 1
      ) || (
        (pagamento == 'Cartao de Credito' || pagamento == 'Cartão de Crédito') &&
        parcelas >= 1 &&
        parcelas <= 12
      );
    }

    function validPedidoCreate() {
      return request.resource.data.keys().hasAll([
          'cliente',
          'pagamento',
          'parcelas',
          'produtos',
          'subtotal',
          'total',
          'frete',
          'ajustes',
          'data',
          'status',
          'userId',
          'estoque_baixado'
        ]) &&
        request.resource.data.keys().hasOnly([
          'cliente',
          'pagamento',
          'parcelas',
          'produtos',
          'subtotal',
          'total',
          'frete',
          'ajustes',
          'data',
          'status',
          'userId',
          'estoque_baixado'
        ]) &&
        validCliente(request.resource.data.cliente) &&
        request.resource.data.parcelas is int &&
        validPagamento(request.resource.data.pagamento, request.resource.data.parcelas) &&
        request.resource.data.produtos is list &&
        request.resource.data.produtos.size() > 0 &&
        request.resource.data.produtos.size() <= 50 &&
        request.resource.data.subtotal is number &&
        request.resource.data.subtotal >= 0 &&
        request.resource.data.subtotal <= 100000 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.total <= 100000 &&
        validFrete(request.resource.data.frete) &&
        validAjustes(request.resource.data.ajustes) &&
        request.resource.data.status == 'pendente' &&
        request.resource.data.estoque_baixado == false &&
        request.resource.data.data == request.time &&
        (
          (!signedIn() && request.resource.data.userId == null) ||
          (signedIn() && request.resource.data.userId == request.auth.uid)
        );
    }

    function validChatMessage(chatId) {
      return request.resource.data.keys().hasOnly(['text', 'sender', 'timestamp', 'userName', 'threadId', 'threadLabel', 'orderId']) &&
        validString(request.resource.data.text, 1, 1000) &&
        request.resource.data.timestamp == request.time &&
        validOptionalString(request.resource.data.threadId, 120) &&
        validOptionalString(request.resource.data.threadLabel, 120) &&
        validOptionalString(request.resource.data.orderId, 120) &&
        (
          (
            isOwner(chatId) &&
            request.resource.data.sender == 'user' &&
            validString(request.resource.data.userName, 1, 80)
          ) ||
          (
            isAdmin() &&
            request.resource.data.sender == 'admin' &&
            validOptionalString(request.resource.data.userName, 80)
          )
        );
    }

    function validChatMeta(chatId) {
      return request.resource.data.keys().hasOnly(['lastMessage', 'lastUpdate', 'userName', 'userId', 'unread', 'activeThreadId', 'activeThreadLabel', 'orderId']) &&
        validOptionalString(request.resource.data.lastMessage, 140) &&
        request.resource.data.lastUpdate is timestamp &&
        validOptionalString(request.resource.data.userName, 80) &&
        validString(request.resource.data.userId, 1, 80) &&
        request.resource.data.userId == chatId &&
        validOptionalString(request.resource.data.activeThreadId, 120) &&
        validOptionalString(request.resource.data.activeThreadLabel, 120) &&
        validOptionalString(request.resource.data.orderId, 120) &&
        request.resource.data.unread is bool;
    }

    function validUserChatMetaWrite(chatId) {
      return isOwner(chatId) &&
        validChatMeta(chatId) &&
        request.resource.data.unread == true &&
        request.resource.data.lastUpdate == request.time &&
        validString(request.resource.data.userName, 1, 80);
    }

    function validAdminChatMetaWrite(chatId) {
      return isAdmin() && validChatMeta(chatId);
    }

    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && validUsuarioData();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read: if isOwner(chatId) || isAdmin();
      allow create: if validChatMessage(chatId);
      allow update, delete: if false;
    }

    match /chats_ativos/{chatId} {
      allow read: if isOwner(chatId) || isAdmin();
      allow create, update: if validUserChatMetaWrite(chatId) || validAdminChatMetaWrite(chatId);
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if false;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /pecas/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /colecoes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /galeria/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_config/{documentId} {
      allow read: if documentId == 'homepage';
      allow write: if isAdmin();
    }

    match /visitas/{document=**} {
      allow create: if false;
      allow read: if isAdmin();
    }

    match /precificacoes/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
